# Các file build của Gradle (Cực kỳ quan trọng)
.gradle/
build/
/*/build/
app/build/
app/release/

# APK / artifact output (không commit)
*.apk
*.aab
output-metadata.json
baselineProfiles/

# Các file cấu hình riêng của máy bạn (Chứa đường dẫn SDK)
local.properties

# Các file của Android Studio / IntelliJ (Tránh xung đột giao diện IDE)
.idea/
*.iml
*.iws
*.ipr
out/

# Các file rác của hệ điều hành
.DS_Store
Thumbs.db

# Các file log và file tạm
*.log
captures/

# Thư mục build của code C++ (nếu có dùng NDK)
.externalNativeBuild
.cxx/
docs/
# Local Android/Gradle state
.android-user/
.gradle-user/
.gradle-build-cache/
.README_Legacy.md