<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Mosquizto" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/geomanist_medium</item>
        <item name="android:windowBackground">@color/background_grey</item>
        <item name="android:statusBarColor">@color/background_grey</item>
        <item name="android:navigationBarColor">@color/background_white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorOnPrimary">@color/app_on_primary</item>
        <item name="colorSurface">@color/background_white</item>
        <item name="colorOnSurface">@color/text_color_primary</item>
        <item name="colorOutline">@color/quizlet_border</item>
    </style>

    <style name="Theme.Mosquizto" parent="Base.Theme.Mosquizto" />

    <style name="OptionMenuItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:drawablePadding">16dp</item>
        <item name="android:paddingVertical">16dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_color_primary</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <style name="SecondaryLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_color_secondary</item> <item name="android:textAllCaps">true</item> <item name="android:layout_marginBottom">8dp</item>
    </style>

    <style name="MatchItemStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_option_default</item>
        <item name="android:padding">16dp</item>
        <item name="android:minHeight">80dp</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:textColor">@color/text_color_primary</item>
    </style>

    <style name="BottomSheetMenuItem" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:paddingVertical">16dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text_color_secondary</item>
        <item name="android:drawablePadding">16dp</item>
        <item name="drawableTint">@color/app_icon_tint</item>
        <item name="android:gravity">center_vertical</item>
        <item name="fontFamily">@font/geomanist_medium</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <!-- Dialog kiểu bottom-sheet tối cho Flashcard Settings -->
    <style name="BottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@drawable/bg_dialog_rounded</item>
    </style>

    <!-- Dialog thông thường dùng nền tối, góc bo -->
    <style name="FlashcardDialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.6</item>
    </style>

    <!-- Switch tùy chỉnh -->
    <style name="FlashcardSwitch" parent="Widget.AppCompat.CompoundButton.Switch">
        <item name="android:thumb">@drawable/switch_thumb</item>
        <item name="android:track">@drawable/switch_track</item>
    </style>

    <!-- Nút toggle (Thuật ngữ / Định nghĩa) -->
    <style name="ToggleButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textSize">13sp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="cornerRadius">8dp</item>
    </style>
</resources>
