<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_grey">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/background_white"
        android:elevation="4dp">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/app_icon_tint"/>
            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/tvToolbarTitle"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_color_primary"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/btnAddHeader"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_add"
                    app:tint="@color/app_icon_tint"
                    android:layout_marginEnd="16dp"/>
                <ImageView
                    android:id="@+id/btnMore"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/icon_more"
                    app:tint="@color/app_icon_tint"/>
            </LinearLayout>
        </RelativeLayout>
    </androidx.appcompat.widget.Toolbar>

    <LinearLayout
        android:id="@+id/layoutFolderHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/toolbar"
        android:background="@color/background_white"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tvFolderDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_color_secondary"
            android:textSize="15sp"
            android:visibility="gone" />
    </LinearLayout>

    <View
        android:id="@+id/dividerFolderHeader"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/layoutFolderHeader"
        android:background="@color/app_divider" />

    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_folder"
            app:tint="@color/quizlet_gray_icon"/>
        <TextView
            android:id="@+id/tvEmptyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tvEmptyTitle"
            android:textColor="@color/text_color_secondary"
            android:layout_marginTop="16dp"
            android:textSize="16sp"/>
        <Button
            android:id="@+id/btnBigAddMaterials"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btnBigAddMaterials"
            android:textColor="@color/app_on_primary"
            android:backgroundTint="@color/primary_color"
            android:layout_marginTop="24dp"
            android:paddingHorizontal="32dp"
            android:textAllCaps="false"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFolderCollections"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/dividerFolderHeader"
        android:clipToPadding="false"
        android:padding="16dp"/>

</RelativeLayout>
