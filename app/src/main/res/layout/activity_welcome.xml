<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/background_grey"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="60dp"
        android:paddingBottom="40dp"
        android:paddingStart="28dp"
        android:paddingEnd="28dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginBottom="36dp"
            android:src="@drawable/logo"
            android:background="@drawable/circle_button_bg"
            android:scaleType="centerCrop"
            android:contentDescription="Illustration" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/headline"
            android:textSize="24sp"
            android:textColor="@color/text_color_primary"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/welcome_terms_text"
            android:textSize="15sp"
            android:textColor="@color/text_color_secondary"
            android:gravity="center"
            android:layout_marginBottom="36dp" />

        <Button
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/custom_btn"
            android:text="@string/continue_with"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/app_on_primary"
            app:backgroundTint="@null"
            android:backgroundTint="@color/primary_color"
            android:layout_marginBottom="14dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnSignUpEmail"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/sign_up"
            android:textSize="20sp"
            android:textColor="@color/text_color_primary"
            android:backgroundTint="@color/app_button_secondary_background"
            android:drawablePadding="10dp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/have_an_account"
                android:textSize="15sp"
                android:textColor="@color/text_color_secondary" />

            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="48dp"
                android:minHeight="48dp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:text="@string/login"
                android:textColor="@color/primary_color"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
