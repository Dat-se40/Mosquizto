<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/custom_edittext_border"
    android:clipToOutline="true"
    android:orientation="vertical"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp">

    <!-- Header -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/background_white">

        <TextView
            android:id="@+id/dialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="44dp"
            android:layout_marginEnd="44dp"
            android:ellipsize="end"
            android:fontFamily="@font/geomanist_bold"
            android:gravity="center"
            android:maxLines="1"
            android:text="Tiêu đề"
            android:textColor="@color/text_color_primary"
            android:textSize="18sp" />

        <ImageButton
            android:id="@+id/btnCloseDialog"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center_vertical|end"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/about_dialog_close_desc"
            android:padding="10dp"
            android:src="@drawable/ic_close"
            app:tint="@color/text_gray" />
    </FrameLayout>

    <!-- Divider dưới header -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/app_divider" />

    <!-- Scrollable Content — chiều cao cố định để dialog không che full màn hình -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="420dp"
        android:scrollbars="vertical"
        android:fadeScrollbars="true"
        android:background="@color/background_white">

        <TextView
            android:id="@+id/dialogContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingMultiplier="1.5"
            android:padding="20dp"
            android:textColor="@color/text_color_primary"
            android:textSize="14sp" />

    </androidx.core.widget.NestedScrollView>

    <!-- Divider trên footer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/app_divider" />

    <!-- Footer: nút Đóng -->
    <TextView
        android:id="@+id/btnDismissDialog"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="@font/geomanist_bold"
        android:gravity="center"
        android:text="@string/about_dialog_close"
        android:textColor="@color/colorPrimary"
        android:textSize="16sp" />

</LinearLayout>