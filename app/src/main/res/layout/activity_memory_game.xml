<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnCloseGame"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close" />

        <TextView
            android:id="@+id/tvRoundName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="ROUND 1"
            android:textSize="23sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings" />
    </RelativeLayout>

    <ProgressBar
        android:id="@+id/progressGame"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#4255FF" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/viewMultipleChoice"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:id="@+id/layoutResultMc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp">
                    <ImageView
                        android:id="@+id/imgResultIconMc"
                        android:layout_width="24dp"
                        android:layout_height="24dp" />
                    <TextView
                        android:id="@+id/tvResultMessageMc"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textStyle="bold" android:textSize="16sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvQuestionMc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="@color/black"
                    android:layout_marginBottom="32dp" />

                <TextView
                    android:id="@+id/btnOption1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_option_default" android:padding="20dp"
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/btnOption2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_option_default" android:padding="20dp"
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/btnOption3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_option_default" android:padding="20dp"
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/btnOption4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_option_default" android:padding="20dp"
                    android:textSize="16sp"
                    android:textColor="@color/black" />

                <Button
                    ndroid:id="@+id/btnContinueMc"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="32dp"
                    android:text="Continue"
                    android:backgroundTint="#4255FF"
                    android:textColor="@color/white"
                    android:visibility="gone" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/viewFillBlank"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvQuestionFb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="@color/black"
                    android:layout_marginBottom="32dp" />

                <LinearLayout
                    android:id="@+id/layoutSkippedResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Give this one a try later" android:textColor="#F44336" android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SKIPPED"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#757575"
                        android:layout_marginTop="16dp"/>

                    <TextView
                        android:id="@+id/tvCorrectAnswerFb"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:padding="20dp"
                        android:background="@drawable/bg_option_correct" android:textColor="#4CAF50" android:textStyle="bold"/>
                </LinearLayout>

                <EditText
                    android:id="@+id/edtAnswer"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:hint="Type the answer"
                    android:background="@drawable/bg_option_default"
                    android:paddingHorizontal="16dp"
                    android:textSize="18sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:id="@+id/btnDontKnow"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="Don't know"
                        android:gravity="center"
                        android:textColor="#4255FF"
                        android:textStyle="bold"
                        android:background="?attr/selectableItemBackground" android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnSubmitFb"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="Enter"
                        android:backgroundTint="#4255FF"
                        android:textColor="@color/white" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnContinueFb"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:text="Continue"
                    android:backgroundTint="#4255FF"
                    android:textColor="@color/white"
                    android:visibility="gone" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/viewSummary"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvSummaryTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="You're doing great!"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/black" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvLearnedTerms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:nestedScrollingEnabled="false" />

                <Button
                    android:id="@+id/btnContinueSummary"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="32dp"
                    android:text="Continue to round 2"
                    android:backgroundTint="#4255FF"
                    android:textColor="@color/white" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>
</LinearLayout>