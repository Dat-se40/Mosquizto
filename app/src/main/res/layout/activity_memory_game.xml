<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_grey">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnCloseGame"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close" />

        <TextView
            android:id="@+id/tvRoundName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/tvRoundName"
            android:textSize="23sp"
            android:textColor="@color/text_color_primary" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings" />
    </RelativeLayout>

    <ProgressBar
        android:id="@+id/progressGame"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:max="100"
        android:progress="0"
        android:progressTint="@color/primary_color" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/viewMultipleChoice"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvModeLabelMc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tvModeLabelMc"
                    android:textColor="@color/text_color_secondary"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/layoutResultMc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp">
                    <ImageView
                        android:id="@+id/imgResultIconMc"
                        android:layout_width="24dp"
                        android:layout_height="24dp" />
                    <TextView
                        android:id="@+id/tvResultMessageMc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvQuestionMc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="@color/text_color_primary"
                    android:layout_marginBottom="32dp" />

                <TextView
                    android:id="@+id/btnOption1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_option_default"
                    android:padding="20dp"
                    android:textSize="16sp"
                    android:textColor="@color/text_color_primary"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/btnOption2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_option_default"
                    android:padding="20dp"
                    android:textSize="16sp"
                    android:textColor="@color/text_color_primary"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/btnOption3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_option_default"
                    android:padding="20dp"
                    android:textSize="16sp"
                    android:textColor="@color/text_color_primary"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/btnOption4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_option_default"
                    android:padding="20dp"
                    android:textSize="16sp"
                    android:textColor="@color/text_color_primary" />

                <Button
                    android:id="@+id/btnContinueMc"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="32dp"
                    android:text="Continue"
                    android:textSize="18sp"
                    android:backgroundTint="@color/primary_color"
                    android:textColor="@color/app_on_primary"
                    android:visibility="gone" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/viewFillBlank"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvModeLabelFb"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tvModeLabelFb"
                    android:textColor="@color/text_color_secondary"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvQuestionFb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="@color/text_color_primary"
                    android:layout_marginBottom="32dp" />

                <LinearLayout
                    android:id="@+id/layoutSkippedResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/tvResultMessageFb"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tvResultMessageFb"
                        android:textColor="#F44336"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tvCorrectAnswer"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_color_secondary"
                        android:layout_marginTop="16dp"/>

                    <TextView
                        android:id="@+id/tvCorrectAnswerFb"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:padding="20dp"
                        android:background="@drawable/bg_option_correct"
                        android:textColor="@color/quizlet_green"
                        android:textSize="15sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <EditText
                    android:id="@+id/edtAnswer"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:hint="@string/edtAnswer"
                    android:background="@drawable/bg_option_default"
                    android:paddingHorizontal="16dp"
                    android:textSize="18sp"
                    android:textColor="@color/text_color_primary"
                    android:textColorHint="@color/search_bar_hint" />

                <LinearLayout
                    android:id="@+id/layoutActionsFb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:id="@+id/btnDontKnow"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="@string/btnDontKnow"
                        android:gravity="center"
                        android:textColor="@color/primary_color"
                        android:textStyle="bold"
                        android:background="?attr/selectableItemBackground" android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnSubmitFb"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="@string/btnSubmitFb"
                        android:backgroundTint="@color/primary_color"
                        android:textColor="@color/app_on_primary" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnContinueFb"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:text="@string/btnContinue"
                    android:backgroundTint="@color/primary_color"
                    android:textColor="@color/app_on_primary"
                    android:textSize="18sp"
                    android:visibility="gone" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/viewTestMatch"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tvModeLabelMatch"
                    android:textColor="@color/text_color_secondary"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:layout_marginBottom="8dp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tvIntroMatching"
                    android:textSize="18sp"
                    android:layout_marginBottom="24dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:weightSum="2">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">
                        <TextView
                            android:id="@+id/btnMatchL1"
                            style="@style/MatchItemStyle"/>
                        <TextView
                            android:id="@+id/btnMatchL2"
                            style="@style/MatchItemStyle"/>
                        <TextView
                            android:id="@+id/btnMatchL3"
                            style="@style/MatchItemStyle"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">
                        <TextView
                            android:id="@+id/btnMatchR1"
                            style="@style/MatchItemStyle"/>
                        <TextView
                            android:id="@+id/btnMatchR2"
                            style="@style/MatchItemStyle"/>
                        <TextView
                            android:id="@+id/btnMatchR3"
                            style="@style/MatchItemStyle"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <RelativeLayout
            android:id="@+id/viewSummary"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp"
            android:visibility="visible">

            <TextView
                android:id="@+id/tvSummaryTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:text="@string/tvSummaryTitle"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/text_color_primary"/>

            <Button
                android:id="@+id/btnContinueSummary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_alignParentBottom="true"
                android:text="@string/btnContinue"
                android:textSize="18sp"
                android:backgroundTint="@color/primary_color"
                android:textColor="@color/app_on_primary" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLearnedTerms"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@id/tvSummaryTitle"
                android:layout_above="@id/btnContinueSummary"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp" />

        </RelativeLayout>
    </FrameLayout>
</LinearLayout>
