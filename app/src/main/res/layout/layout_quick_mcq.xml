<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/multiChoiceLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@color/white">

        <TextView
            android:id="@+id/tvQuestionNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 / 1"
            android:textColor="@color/text_color_secondary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvQuestionContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Study Guides instantly turn your notes into out..."
            android:textSize="22sp"
            android:textColor="@color/text_color_primary" />

        <TextView
            android:id="@+id/btnAnswer1"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_outline_button"
            android:text="Anticipation Guides"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:textSize="16sp"
            android:textColor="@color/text_color_primary" />

        <TextView
            android:id="@+id/btnAnswer2"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_outline_button"
            android:text="Textbooks"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:textSize="16sp"
            android:textColor="@color/text_color_primary" />

        <TextView
            android:id="@+id/btnAnswer3"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_outline_button"
            android:text="Study Guides"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:textSize="16sp"
            android:textColor="@color/text_color_primary" />

        <TextView
            android:id="@+id/btnAnswer4"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_outline_button"
            android:text="References"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:textSize="16sp"
            android:textColor="@color/text_color_primary" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>