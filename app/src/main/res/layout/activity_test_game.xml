<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnCloseTest"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Test"
            android:textSize="23sp"
            android:textColor="@color/black" />
    </RelativeLayout>

    <ProgressBar
        android:id="@+id/progressTest"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#4255FF" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView android:id="@+id/viewTestMc"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MULTIPLE CHOICE"
                    style="@style/SecondaryLabel"/>
                <TextView
                    android:id="@+id/tvQuestionMc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="@color/black"
                    android:layout_marginBottom="32dp" />

                <TextView
                    android:id="@+id/btnOption1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_option_default"
                    android:padding="20dp"
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:layout_marginBottom="12dp" />
                <TextView
                    android:id="@+id/btnOption2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_option_default"
                    android:padding="20dp"
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:layout_marginBottom="12dp" />
                <TextView
                    android:id="@+id/btnOption3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_option_default"
                    android:padding="20dp"
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:layout_marginBottom="12dp" />
                <TextView
                    android:id="@+id/btnOption4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_option_default"
                    android:padding="20dp"
                    android:textSize="16sp"
                    android:textColor="@color/black" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/viewTestFb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TYPE THE ANSWER"
                    style="@style/SecondaryLabel"/>
                <TextView
                    android:id="@+id/tvQuestionFb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="@color/black"
                    android:layout_marginBottom="32dp" />
                <EditText
                    android:id="@+id/edtAnswer"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:hint="Type here..."
                    android:background="@drawable/bg_option_default"
                    android:paddingHorizontal="16dp"
                    android:textSize="18sp" />
                <Button
                    android:id="@+id/btnSubmitFb"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:text="Enter"
                    android:backgroundTint="#4255FF"
                    android:textColor="@color/white" />
                <TextView
                    android:id="@+id/tvCorrectAnswerFb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:padding="20dp"
                    android:background="@drawable/bg_option_correct"
                    android:textColor="#4CAF50"
                    android:textStyle="bold"
                    android:visibility="gone"/>
                <Button
                    android:id="@+id/btnContinueFb"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:text="Continue"
                    android:backgroundTint="#4255FF"
                    android:textColor="@color/white"
                    android:visibility="gone" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/viewTestMatch"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MATCHING"
                    style="@style/SecondaryLabel"
                    android:layout_marginBottom="16dp"
                    android:textSize="20sp"
                    android:textColor="@color/black"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tap a term, then tap its definition."
                    android:textSize="20sp"
                    android:layout_marginBottom="24dp"
                    android:fontFamily="@font/geomanist_regular"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">
                        <TextView
                            android:id="@+id/btnMatchL1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_option_default"
                            android:padding="16dp"
                            android:minHeight="80dp"
                            android:gravity="center"
                            android:layout_marginBottom="12dp"
                            android:textColor="@color/black"
                            android:fontFamily="@font/geomanist_regular"/>
                        <TextView
                            android:id="@+id/btnMatchL2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_option_default"
                            android:padding="16dp"
                            android:minHeight="80dp"
                            android:gravity="center"
                            android:layout_marginBottom="12dp"
                            android:textColor="@color/black"
                            android:fontFamily="@font/geomanist_regular"/>
                        <TextView
                            android:id="@+id/btnMatchL3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_option_default"
                            android:padding="16dp"
                            android:minHeight="80dp"
                            android:gravity="center"
                            android:textColor="@color/black"
                            android:fontFamily="@font/geomanist_regular"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">
                        <TextView
                            android:id="@+id/btnMatchR1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_option_default"
                            android:padding="16dp"
                            android:minHeight="80dp"
                            android:gravity="center"
                            android:layout_marginBottom="12dp"
                            android:textColor="@color/black"
                            android:fontFamily="@font/geomanist_regular"/>
                        <TextView
                            android:id="@+id/btnMatchR2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_option_default"
                            android:padding="16dp"
                            android:minHeight="80dp"
                            android:gravity="center"
                            android:layout_marginBottom="12dp"
                            android:textColor="@color/black"
                            android:fontFamily="@font/geomanist_regular"/>
                        <TextView
                            android:id="@+id/btnMatchR3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_option_default"
                            android:padding="16dp"
                            android:minHeight="80dp"
                            android:gravity="center"
                            android:textColor="@color/black"
                            android:fontFamily="@font/geomanist_regular"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/viewSummary"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">
                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_check"
                    app:tint="#4CAF50"
                    android:layout_marginTop="32dp"/>
                <TextView
                    android:id="@+id/tvFinalScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="You scored 100%!"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginTop="24dp"/>
                <Button
                    android:id="@+id/btnFinishTest"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="32dp"
                    android:text="Done"
                    android:backgroundTint="#4255FF"
                    android:textColor="@color/white" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>
</LinearLayout>