<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_grey">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/imageButton_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:srcCompat="@drawable/baseline_arrow_back_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/imageButton_back"
                app:tint="@color/app_icon_tint"
                android:layout_marginStart="30dp"
                android:layout_marginTop="40dp"
                />

            <TextView
                android:id="@+id/textView_ResetPass"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="40dp"
                android:layout_marginTop="20dp"
                android:text="@string/textView_ResetPass"
                android:textColor="@color/text_color_primary"
                android:textSize="40sp" />

            <TextView
                android:id="@+id/textView_NoteResetPass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="40dp"
                android:layout_marginTop="20dp"
                android:text="@string/textView_NoteResetPass"
                android:textColor="@color/text_color_secondary"
                android:textSize="22sp"
                android:layout_marginEnd="40dp"
                android:fontFamily="@font/geomanist_light"/>

            <EditText
                android:id="@+id/editText_MailReset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/custom_edittext_border"
                android:ems="10"
                android:hint="@string/editText_MailReset"
                android:inputType="textEmailAddress"
                android:textColorHint="@color/search_bar_hint"
                android:textSize="23sp"
                android:layout_marginStart="40dp"
                android:layout_marginTop="25dp"
                android:layout_marginEnd="40dp"
                android:textColor="@color/text_color_primary"/>

            <Button
                android:id="@+id/btn_SendLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/custom_btn"
                android:enabled="false"
                android:text="@string/btn_SendLink"
                android:textColor="@color/app_on_primary"
                android:textSize="23sp"
                android:textStyle="bold"
                app:backgroundTint="@null"
                android:layout_marginStart="40dp"
                android:layout_marginTop="350dp"
                android:layout_marginEnd="40dp"/>


        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
