<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.Mosquizto"
        android:name=".MosquiztoApp">

        <activity
            android:name=".Activities.Login"
            android:exported="false"
            android:label="@string/title_activity_login_form"
            android:theme="@style/Theme.Mosquizto">
        </activity>

        <activity
            android:name=".Activities.CreateAccountActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false">
        </activity>

        <activity
            android:name=".Activities.ResetPass"
            android:exported="false"
            android:theme="@style/Theme.Mosquizto" />

        <activity
            android:name=".Activities.ResetPasswordFlowActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Mosquizto" />

        <activity
            android:name=".Activities.RSPassNoti"
            android:exported="false"
            android:theme="@style/Theme.Mosquizto" />

        <activity android:name=".Activities.ProfilePage"
            android:exported="false"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Mosquizto" />

        <activity android:name=".Activities.OtherUserProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Mosquizto" />

        <activity android:name=".Activities.FollowListActivity"
            android:exported="false"
            android:theme="@style/Theme.Mosquizto" />

        <activity
            android:name=".Activities.SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Mosquizto" />

        <activity
            android:name=".Activities.AchievementActivity"
            android:exported="false"
            android:theme="@style/Theme.Mosquizto" />

        <activity
            android:name=".Activities.NotificationActivity"
            android:exported="false"
            android:theme="@style/Theme.Mosquizto" />

        <activity
            android:name=".Activities.CreateCollectionActivity"
            android:exported="false" />

        <activity
            android:name=".Activities.EditCollectionActivity"
            android:exported="false" />

        <activity
            android:name=".Activities.CollectionSettingsActivity"
            android:exported="false" />

        <activity
            android:name=".Activities.StudySetDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Mosquizto" />

        <activity android:name=".Activities.MemoryGameActivity"
            android:exported="false"
            android:theme="@style/Theme.Mosquizto"/>
        <activity
            android:name=".MainActivity"
            android:exported="false">
        </activity>

        <activity
            android:name=".Activities.FlashcardActivity"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".Activities.FlashcardSummaryActivity" />

        <activity android:name=".Activities.WelcomeActivity" android:exported="true"
            android:theme="@style/Theme.Mosquizto">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".Activities.FolderDetailActivity"
            android:exported="false" />

        <activity android:name=".Activities.AddStudyMaterialsActivity"
            android:exported="false" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <!-- Ngăn chặn WorkManager default initializer -->
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>

</manifest>
